generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String       @id @default(uuid())
  name                 String
  email                String       @unique
  password             String
  role                 String       @default("user")
  refreshToken         String?
  avatar               String?
  isVerified           Boolean      @default(false)
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  profile              UserProfile?
  hrDirectJobMatches   HrDirectJobMatch[]

  @@map("users")
}

model UserProfile {
  id                 String    @id @default(uuid())
  userId             String    @unique
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName           String?
  phone              String?
  location           String?
  currentRole        String?
  experience         Int?

  linkedInUrl        String?
  githubUrl          String?
  portfolioUrl       String?

  currentCompany     String?
  currentCTC         Float?
  expectedCTC        Float?
  noticePeriod       Int?
  employmentType     String?

  skills             String[]  @default([])
  techStacks         String[]  @default([])

  preferredRoles     String[]  @default([])
  preferredLocations String[]  @default([])
  salaryExpectation  Float?
  remotePreference   String?
  openToRelocation   Boolean   @default(false)

  resumeUrl          String?
  resumeName         String?
  resumeKey          String?
  resumeUploadedAt   DateTime?

  isComplete         Boolean   @default(false)

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("user_profiles")
}

model Job {
  id          String    @id @default(uuid())
  title       String
  company     String?
  location    String?
  source      String
  applyUrl    String    @unique
  description String?   @db.Text
  snippet     String?
  skills      String[]  @default([])
  postedAt    DateTime?
  postedText  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([source])
  @@index([createdAt])
  @@index([postedAt])
  @@map("jobs")
}

model HrDirectJob {
  id                 String              @id @default(uuid())
  title              String
  company            String?
  location           String?
  experienceRequired String?
  skills             String[]            @default([])
  hrName             String?
  hrEmail            String
  description        String?             @db.Text
  sourceUrl          String              @unique
  source             String              @default("linkedin")
  workMode           String?
  postedAt           DateTime?
  postedText         String?
  rawSnippet         String?
  searchKeyword      String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  matches            HrDirectJobMatch[]

  @@index([source])
  @@index([hrEmail])
  @@index([workMode])
  @@index([createdAt])
  @@map("hr_direct_jobs")
}

model HrDirectJobMatch {
  id                 String      @id @default(uuid())
  userId             String
  hrDirectJobId      String
  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  job                HrDirectJob @relation(fields: [hrDirectJobId], references: [id], onDelete: Cascade)
  matchScore         Int         @default(0)
  missingSkills      String[]    @default([])
  matchReason        String?     @db.Text
  tailoredResumeText String?     @db.Text
  coverLetter        String?     @db.Text
  recruiterEmailBody String?     @db.Text
  emailSentAt        DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@unique([userId, hrDirectJobId])
  @@index([userId, matchScore])
  @@map("hr_direct_job_matches")
}
